   "source": [
    "def retrieve(query, top_k=5):\n",
    "\n",
    "    docs = retriever.invoke(query)\n",
    "\n",
    "    pairs = [\n",
    "        [query, doc.page_content]\n",
    "        for doc in docs\n",
    "    ]\n",
    "\n",
    "    scores = reranker.predict(pairs)\n",
    "\n",
    "    ranked_docs = sorted(\n",
    "        zip(scores, docs),\n",
    "        key=lambda x: x[0],\n",
    "        reverse=True\n",
    "    )\n",
    "\n",
    "    return [\n",
    "        doc\n",
    "        for score, doc in ranked_docs[:top_k]\n",
    "    ]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 29,
   "id": "65da40e6-798d-4464-876c-7f0e0deb287a",
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_context(query):\n",
    "\n",
    "    retrieved_docs = retrieve(query)\n",
    "\n",
    "    context = \"\\n\\n\".join(\n",
    "        doc.page_content\n",
    "        for doc in retrieved_docs\n",
    "    )\n",
    "\n",
    "    return context"
   ]
  },
