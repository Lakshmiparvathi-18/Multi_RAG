    "import ollama\n",
    "def ask_llm(prompt):\n",
    "    response = ollama.chat(\n",
    "        model = \"llama3:8b\",\n",
    "        messages = [{\n",
    "            \"role\" : \"user\",\n",
    "            \"content\" : prompt\n",
    "        }],\n",
    "        stream = true\n",
    "    )\n",
    "    for res in response:\n",
    "        print(res['messages']['content'],end=\"\",flush = True)"
   ]
  },
